rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Validation for Message
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'timestamp', 'status']) &&
             data.keys().size() == 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 500 &&
             data.subject is string && data.subject.size() >= 0 && data.subject.size() < 500 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.timestamp == request.time &&
             data.status == 'new';
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      // Only authenticated admins could read messages. 
      // For now, since there's no defined admin list, we keep it secure.
      allow read: if false; 
    }
  }
}
